{
  "name": "expo-template-default",
  "license": "0BSD",
  "main": "expo-router/entry",
  "version": "54.0.35",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios-device": "expo run:ios --device \"iPhone di Alessandro\"",
    "test-device-pt1": "npx expo prebuild --clean",
    "test-device-pt2": "npx expo run:android",
    "test-device-ios": "npx expo run:ios",
    "doctor": "npx expo-doctor",
    "typecheck": "tsc --noEmit",
    "web": "expo start --web",
    "lint": "expo lint",
    "draft": "npx eas-cli@latest workflow:run create-draft.yml",
    "development-builds": "npx eas-cli@latest workflow:run create-development-builds.yml",
    "deploy": "npx eas-cli@latest workflow:run deploy-to-production.yml",
    "build-android-preview": "eas build --platform android --profile preview",
    "build-android-prod": "eas build --platform android --profile production",
    "build-ios-preview": "eas build --platform ios --profile preview",
    "build-ios-prod": "eas build --platform ios --profile production",
    "submit-ios-prod": "eas submit --platform ios --profile production"
  },
  "dependencies": {
    "@expo/metro-runtime": "~57.0.6",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.1",
    "expo": "^57.0.0",
    "expo-apple-authentication": "~57.0.1",
    "expo-build-properties": "~57.0.6",
    "expo-constants": "~57.0.6",
    "expo-dev-client": "~57.0.7",
    "expo-device": "~57.0.1",
    "expo-document-picker": "~57.0.1",
    "expo-file-system": "~57.0.1",
    "expo-font": "~57.0.1",
    "expo-haptics": "~57.0.1",
    "expo-image": "~57.0.1",
    "expo-image-picker": "~57.0.5",
    "expo-keep-awake": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-location": "~57.0.5",
    "expo-router": "~57.0.7",
    "expo-sharing": "~57.0.6",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "expo-symbols": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "expo-updates": "~57.0.8",
    "expo-web-browser": "~57.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.10.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~57.0.0",
    "typescript": "~6.0.3"
  }
}
