    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "expo": "^55.0.0",
    "expo-apple-authentication": "~55.0.15",
    "expo-build-properties": "~55.0.16",
    "expo-constants": "~55.0.17",
    "expo-dev-client": "~55.0.37",
    "expo-device": "~55.0.19",
    "expo-document-picker": "~55.0.15",
    "expo-file-system": "~55.0.24",
    "expo-font": "~55.0.8",
    "expo-haptics": "~55.0.16",
    "expo-image": "~55.0.11",
    "expo-image-picker": "~55.0.22",
    "expo-keep-awake": "~55.0.8",
    "expo-linking": "~55.0.16",
    "expo-location": "~55.1.12",
    "expo-router": "~55.0.17",
    "expo-sharing": "~55.0.22",
    "expo-splash-screen": "~55.0.23",
    "expo-status-bar": "~55.0.6",
    "expo-symbols": "~55.0.9",
    "expo-system-ui": "~55.0.20",
    "expo-updates": "~55.0.26",
    "expo-web-browser": "~55.0.18",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.1",
    "typescript": "~5.9.2"
  }
